{
  "name": "js-okf",
  "version": "0.2.1",
  "description": "TypeScript library for creating and updating Open Knowledge Format (OKF) bundles — markdown-based knowledge files for AI coding agents",
  "keywords": [
    "okf",
    "open-knowledge-format",
    "llm",
    "ai-agent",
    "coding-agent",
    "knowledge-base",
    "markdown",
    "yaml",
    "frontmatter",
    "context",
    "memory",
    "typescript"
  ],
  "author": "Prabhay Gupta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prabhay759/js-okf.git"
  },
  "homepage": "https://github.com/prabhay759/js-okf#readme",
  "bugs": {
    "url": "https://github.com/prabhay759/js-okf/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "bin": {
    "okf": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:vendor": "esbuild node_modules/highlight.js/lib/common.js --bundle --format=iife --global-name=hljs --outfile=dist/vendor/hljs.js && cp node_modules/highlight.js/styles/github.min.css dist/vendor/hljs.css && cp node_modules/marked/lib/marked.umd.js dist/vendor/marked.js && esbuild scripts/vendor-d3.mjs --bundle --format=iife --global-name=d3 --minify --outfile=dist/vendor/d3.js",
    "build": "tsup",
    "postbuild": "npm run build:vendor",
    "dev": "tsup --watch",
    "serve": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "js-yaml": "^5.0.0",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "d3": "^7.9.0",
    "puppeteer": "^25.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
